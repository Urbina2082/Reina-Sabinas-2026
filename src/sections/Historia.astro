---
import InitSection from "../components/InitSection.astro";
import Card from "../components/Historia/Historia.astro";
---

<div class="Historia">
  <InitSection
    title="NUESTRA HISTORIA"
    subtitle="ACERCA DEL"
    subtitle2="REINADO"
    description="El Certamen de Reina de Sabinas es una tradición que celebra la belleza, inteligencia y carisma de las mujeres que orgullosamente representan a nuestra ciudad. Cada año, las participantes demuestran su compromiso con la comunidad a través de actividades culturales, sociales y de impacto."
  />

  <div class="cards">
    <Card
      icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#49654d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar mx-auto text-gold mb-3"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>'
      number="84+"
      title="AÑOS DE TRADICIÓN"
    />
    <Card
      icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#49654d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users mx-auto text-gold mb-3"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>'
      number="400+"
      title="PARTICIPANTES HISTÓRICAS"
    />
    <Card
      icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#49654d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-crown mx-auto text-gold mb-3"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z"></path><path d="M5 21h14"></path></svg>'
      number="8"
      title="CANDIDATAS ESTE AÑO"
    />
    <Card
      icon='<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#49654d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy mx-auto text-gold mb-3"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>' 
      number="1"
      title="CORONA POR CONQUISTAR"
    />
  </div>
</div>

<style>

  .Historia {
 margin: 7rem 0rem ;
  }

.cards{
    display:flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 60px;
}
@media (max-width: 768px) {
    .cards{
       gap: 30px;
    }
}
</style>